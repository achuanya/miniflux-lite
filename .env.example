# --- Miniflux API 配置 ---
# Miniflux 服务器地址
API_URL=https://miniflux.example.com

# Miniflux API 访问令牌（在 Miniflux 后台 Settings -> API Keys 生成）
API_TOKEN=your_miniflux_api_token_here

# 需要聚合的 Miniflux 分类名称列表（逗号分隔）
CATEGORIES=我的订阅,网上邻居

# --- 输出配置 ---

# 聚合结果 JSON 文件的存储路径
FILE_PATH=/data/feed.json

# --- 日志配置 ---
# 日志级别 (DEBUG, INFO, WARN, ERROR, DPANIC, PANIC, FATAL)
LOG_LEVEL=info
# 日志文件路径 (留空则输出到控制台 stdout)
LOG_FILE_PATH=
# 日志输出格式 (json, console) - json为结构化日志, console为易读格式
LOG_ENCODER=console

# --- 并发控制配置 ---
# 并发获取订阅源数据的最大 goroutine 数量 (设置为 1 则不使用并发)
MAX_CONCURRENT_GOROUTINES=5

# --- 其他配置 ---
# HTTP 请求超时时间 (单位: 秒)
HTTP_TIMEOUT_SECONDS=30

# HTTP User-Agent（可选）
HTTP_USER_AGENT=MiniFlux-Lite/1.0 (+https://yourdomain.com)
